# ── SMTP Configuration ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Your sending account
EMAIL_USERNAME=you@gmail.com

# For Gmail, use an App Password (not your login password):
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASSWORD=your_app_password_here

# Optional: override the From address (defaults to EMAIL_USERNAME)
EMAIL_FROM=you@gmail.com

# true  → STARTTLS on port 587 (recommended for Gmail/Outlook)
# false → SMTP_SSL on port 465
EMAIL_USE_TLS=true
